generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id                  String       @id @default(cuid())
  joinToken           String       @unique @default(cuid())
  dmSecret            String       @unique @default(cuid())
  planningWindowStart DateTime?
  planningWindowEnd   DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  description         String?
  dmId                String?
  maxPlayers          Int?
  name                String?
  dm                  DM?          @relation(fields: [dmId], references: [id])
  playerSlots         PlayerSlot[]
}

model PlayerSlot {
  id                  String              @id @default(cuid())
  campaignId          String
  name                String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  availabilityEntries AvailabilityEntry[]
  campaign            Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AvailabilityEntry {
  id           String     @id @default(cuid())
  playerSlotId String
  type         String
  dayOfWeek    Int?
  date         DateTime?
  timeOfDay    String?
  status       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  playerSlot   PlayerSlot @relation(fields: [playerSlotId], references: [id], onDelete: Cascade)

  @@unique([playerSlotId, date])
}

model DM {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  campaigns    Campaign[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  dmId      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  dm        DM       @relation(fields: [dmId], references: [id], onDelete: Cascade)
}
